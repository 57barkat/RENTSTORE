# Ignore everything by default

-

# Keep the Expo app directory

!frontend/
!frontend/\*\*

# Inside frontend, still exclude local/generated junk

frontend/node_modules/
frontend/.expo/
frontend/.expo-shared/
frontend/dist/
frontend/web-build/
frontend/.idea/
frontend/.vscode/

# Native/build caches

frontend/android/.gradle/
frontend/android/build/
frontend/android/app/build/
frontend/android/.cxx/
frontend/android/app/.cxx/
frontend/android/app/.externalNativeBuild/

frontend/ios/Pods/
frontend/ios/build/
frontend/ios/.symlinks/

# Logs / OS junk

frontend/**/\*.log
frontend/**/.DS_Store
